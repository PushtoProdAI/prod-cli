[
  {
    "name": "deploy",
    "input": {
      "type": "object",
      "properties": {
        "prompt": {
          "type": "string",
          "description": "the natural-language deploy request, e.g. 'deploy this to fly with a postgres'"
        },
        "confirm": {
          "type": "boolean",
          "description": "set true to ACTUALLY deploy (destructive, provisions cloud resources, costs money); false or omitted only PREVIEWS the plan and estimated cost and deploys nothing"
        },
        "path": {
          "type": "string",
          "description": "the project directory to deploy (defaults to the current directory)"
        },
        "planDigest": {
          "type": "string",
          "description": "the planDigest returned by a prior confirm=false preview of the SAME prompt and path; REQUIRED when confirm=true — deploy is refused without it, so you must preview and show the human the plan first"
        }
      },
      "required": [
        "prompt"
      ],
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "deployed": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "url": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "plan": {
          "type": [
            "null",
            "object"
          ],
          "properties": {
            "action": {
              "type": "string"
            },
            "platform": {
              "type": "string"
            },
            "shape": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            },
            "estimatedMonthlyCostUsd": {
              "type": "number"
            }
          },
          "additionalProperties": false
        },
        "planDigest": {
          "type": "string"
        }
      },
      "required": [
        "deployed",
        "status"
      ],
      "additionalProperties": false
    }
  },
  {
    "name": "list_deploys",
    "input": {
      "type": "object",
      "properties": {
        "limit": {
          "type": "integer",
          "description": "maximum number of deployments to return, most recent first (0 uses the default of 20)"
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "mode": {
          "type": "string"
        },
        "deployments": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "operationType": {
                "type": "string"
              },
              "resourceName": {
                "type": "string"
              },
              "platform": {
                "type": "string"
              },
              "language": {
                "type": "string"
              },
              "status": {
                "type": "string"
              },
              "url": {
                "type": "string"
              },
              "startedAt": {
                "type": "string"
              },
              "completedAt": {
                "type": "string"
              }
            },
            "required": [
              "id",
              "operationType",
              "resourceName",
              "platform",
              "language",
              "status",
              "startedAt"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "mode",
        "deployments"
      ],
      "additionalProperties": false
    }
  },
  {
    "name": "analyze_project",
    "input": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "path to the project directory to analyze (defaults to the current directory)"
        }
      },
      "additionalProperties": false
    },
    "output": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string"
        },
        "language": {
          "type": "string"
        },
        "buildCommand": {
          "type": "string"
        },
        "startCommand": {
          "type": "string"
        },
        "services": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string"
              },
              "provider": {
                "type": "string"
              }
            },
            "required": [
              "type",
              "provider"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "name",
        "language",
        "services"
      ],
      "additionalProperties": false
    }
  },
