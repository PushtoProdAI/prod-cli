# Copy this file to .env and fill in your values

# Environment Configuration
# Options: local, staging, production
# Default: staging (for local development)
ENVIRONMENT=staging

SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
# enables the go-workflows UI and a logging UI
PROD_DEBUG=true
# Error tracking is OPT-IN and off by default. prod never reports to us. To send
# errors to YOUR OWN Sentry, set your own DSN:
# PROD_SENTRY_DSN=https://<your-key>@<your-org>.ingest.sentry.io/<project>
# account ID of OUR AWS account to use (we have prod-staging and prod-production)
PROD_AWS_ACCOUNT_ID=
# used for deploying to customer AWS accounts. We have two, one for staging and one for production
AWS_CLOUDFORMATION_TEMPLATE_URL=https://prod-aws-deploy-staging.s3.us-east-1.amazonaws.com/cloudformation-templates/cloudformation-deploy-role-template.yaml