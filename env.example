# prod configuration — copy to .env and uncomment what you need.
#
# prod is a local tool: it runs on your machine, keeps state in ~/.prod, and
# talks to each cloud with YOUR OWN credentials. There is no prod account and
# nothing is sent to a prod server. Most platform credentials are picked up from
# the platform's own CLI login (fly auth login, gcloud, az, …) — you only need
# the variables below when you'd rather not log in interactively (CI, headless).
#
# Full per-cloud setup, including how to obtain each token:
#   https://github.com/PushtoProdAI/prod-cli/blob/main/docs/clouds.md

# ─────────────────────────────────────────────────────────────────────────────
# LLM — REQUIRED. prod parses your English request with an LLM you provide.
# The call goes direct to the provider with your key; set ONE of the following.
# Priority when several are present: OpenAI > Anthropic > local Ollama.
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — create a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic — create a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# Fully local, zero-cost, nothing leaves your machine: run Ollama instead of
# setting a cloud key (https://ollama.com). Override the endpoint if it's remote:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Force a specific model for whichever provider was selected (optional):
# PROD_LLM_MODEL=gpt-4o-mini

# ─────────────────────────────────────────────────────────────────────────────
# prod itself (all optional)
# ─────────────────────────────────────────────────────────────────────────────

# Verbose logs + the go-workflows debug UI:
# PROD_DEBUG=true

# Error reporting is OFF by default and prod never reports to us. To send errors
# to YOUR OWN Sentry, set your own DSN:
# PROD_SENTRY_DSN=https://<your-key>@<your-org>.ingest.sentry.io/<project>

# ─────────────────────────────────────────────────────────────────────────────
# Platform credentials — set ONLY the cloud you're deploying to. For most
# clouds the CLI-login route (shown in comments) is easier than a raw token.
# ─────────────────────────────────────────────────────────────────────────────

# Fly.io — `fly auth login`, or a token (fly.io dashboard → Account → Tokens):
# FLY_API_TOKEN=

# Render — Dashboard → Account Settings → API Keys → Create API Key:
# RENDER_API_KEY=

# Vercel — `vercel login`, or a token (Vercel → Settings → Tokens):
# VERCEL_TOKEN=

# Netlify — `netlify login`, or a token (Netlify → User settings →
# Applications → Personal access tokens):
# NETLIFY_AUTH_TOKEN=

# Cloudflare Pages (static sites) — create a token at
# dash.cloudflare.com → My Profile → API Tokens → Create Token, scoped
# Account → Cloudflare Pages → Edit. Your Account ID is in the dashboard URL
# and on the right sidebar of the Workers & Pages overview. Both are required:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Heroku — `heroku login`, or an API key (`heroku authorizations:create`, or
# Account settings → API Key). HEROKU_AUTH_TOKEN is accepted as an alias:
# HEROKU_API_KEY=

# AWS App Runner — uses the standard AWS chain, exactly like the AWS CLI. If
# `aws sts get-caller-identity` works, prod works. Pick however you configure AWS:
# AWS_PROFILE=my-profile
# AWS_REGION=us-east-1
#   …or AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY (/ AWS_SESSION_TOKEN), or SSO.

# Google Cloud Run — `gcloud auth application-default login` (or point
# GOOGLE_APPLICATION_CREDENTIALS at a service-account key). Project is required:
# GOOGLE_CLOUD_PROJECT=my-project
# PROD_GCP_REGION=us-central1     # optional (default us-central1)
# PROD_GCP_AR_REPO=prod           # optional Artifact Registry repo (created on demand)

# Azure Container Apps — `az login` (or a service principal via
# AZURE_CLIENT_ID / AZURE_TENANT_ID / AZURE_CLIENT_SECRET). Subscription required:
# AZURE_SUBSCRIPTION_ID=
# PROD_AZURE_RESOURCE_GROUP=prod-apps   # optional (created on demand)
# PROD_AZURE_LOCATION=eastus            # optional
# PROD_AZURE_ACR=                       # optional; globally-unique ACR name
# PROD_AZURE_ACA_ENV=prod-env           # optional Container Apps environment name

# Modal (experimental) — `pip install modal` then `modal token new`, or set:
# MODAL_TOKEN_ID=
# MODAL_TOKEN_SECRET=
# MODAL_ENTRYPOINT=app.py               # optional; the .py that defines modal.App(...)

# ─────────────────────────────────────────────────────────────────────────────
# Container registry — only for Render, which pulls the image from a registry
# YOU own. (AWS/Cloud Run/Azure push to your ECR/GAR/ACR automatically.)
# ─────────────────────────────────────────────────────────────────────────────

# Docker Hub (the default) — token at Docker Hub → Account Settings → Security →
# New Access Token:
# PROD_REGISTRY=dockerhub
# PROD_REGISTRY_USERNAME=your-dockerhub-user
# PROD_REGISTRY_TOKEN=dckr_pat_...

# GitHub Container Registry (GHCR) — a PAT with write:packages:
# PROD_REGISTRY=ghcr
# PROD_REGISTRY_NAMESPACE=your-gh-user-or-org
# PROD_REGISTRY_USERNAME=your-gh-user
# PROD_REGISTRY_TOKEN=ghp_...

# Any other registry:
# PROD_REGISTRY=generic
# PROD_REGISTRY_HOST=registry.gitlab.com
# PROD_REGISTRY_NAMESPACE=your-namespace
# PROD_REGISTRY_USERNAME=your-user
# PROD_REGISTRY_TOKEN=...
